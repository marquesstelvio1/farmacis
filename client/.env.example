# API Configuration
VITE_API_URL=https://your-render-app.onrender.com

# Application
VITE_APP_NAME=Farmácia Digital
VITE_APP_URL=https://your-vercel-app.vercel.app

# Google Maps API Key - Get from https://console.cloud.google.com/
VITE_GOOGLE_MAPS_KEY=your_google_maps_api_key_here

# AI Assistant Configuration
# Enable/disable AI assistant responses (true/false)
VITE_ASSISTANT_ENABLED=true
# Enable catalog database integration for medication queries (true/false)
VITE_ASSISTANT_CATALOG_INTEGRATION=true
# Maximum number of products to return from catalog queries
VITE_ASSISTANT_MAX_CATALOG_RESULTS=5
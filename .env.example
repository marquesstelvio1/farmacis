# Database (Supabase Connection String)
DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres?pgbouncer=true&connection_limit=1

# AI Services
OPENAI_API_KEY=your_openai_api_key_here

# Payment Processing
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Farmácia Digital <noreply@farmacia.com>"

# Application
APP_URL=https://your-vercel-app.vercel.app
NODE_ENV=production
PORT=10000
HOST=0.0.0.0

# Session Security (Generate a secure random string)
SESSION_SECRET=your-very-secure-random-session-secret-here-min-32-chars

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads

# Frontend URL (for CORS)
FRONTEND_URL=https://your-vercel-app.vercel.app